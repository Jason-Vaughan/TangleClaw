{
  "id": "gemini",
  "name": "Gemini CLI",
  "command": "gemini",
  "interactionModel": "session",
  "configFormat": {
    "filename": ".gemini/GEMINI.md",
    "syntax": "markdown",
    "generator": "gemini-md"
  },
  "coAuthorFormat": "Co-Authored-By: {name} <{email}>",
  "commands": [],
  "detection": {
    "strategy": "which",
    "target": "gemini"
  },
  "launch": {
    "shellCommand": "gemini",
    "args": [],
    "env": {}
  },
  "persistent": null,
  "capabilities": {
    "supportsSlashCommands": false,
    "supportsPrimePrompt": true,
    "supportsConfigFile": true,
    "supportsCoAuthor": true
  },
  "statusPage": {
    "adapter": "google-incidents",
    "url": "https://status.cloud.google.com/incidents.json",
    "productName": "Gemini"
  }
}
