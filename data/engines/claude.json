{
  "id": "claude",
  "name": "Claude Code",
  "command": "claude",
  "interactionModel": "session",
  "configFormat": {
    "filename": "CLAUDE.md",
    "syntax": "markdown",
    "generator": "claude-md"
  },
  "coAuthorFormat": "Co-Authored-By: {name} <{email}>",
  "commands": [
    { "label": "Compact", "input": "/compact", "description": "Compress context" },
    { "label": "Clear", "input": "/clear", "description": "Clear conversation" },
    { "label": "Review", "input": "/review", "description": "Review recent changes" }
  ],
  "detection": {
    "strategy": "which",
    "target": "claude"
  },
  "launch": {
    "shellCommand": "claude",
    "args": [],
    "env": {},
    "startupDelay": 2000
  },
  "launchModes": {
    "default": { "label": "Interactive", "args": [], "description": "Prompts for permission on every action" },
    "acceptEdits": { "label": "Accept Edits", "args": ["--permission-mode", "acceptEdits"], "description": "Auto-accepts file reads and edits" },
    "plan": { "label": "Plan Only", "args": ["--permission-mode", "plan"], "description": "Read-only, no code changes" },
    "auto": { "label": "Auto", "args": ["--permission-mode", "auto", "--enable-auto-mode"], "description": "Full autonomy with safety classifier" },
    "bypassPermissions": { "label": "Bypass", "args": ["--dangerously-skip-permissions"], "description": "Accepts everything (containers/VMs only)", "warning": "Only use in isolated environments" }
  },
  "defaultLaunchMode": "default",
  "persistent": null,
  "capabilities": {
    "supportsSlashCommands": true,
    "supportsPrimePrompt": true,
    "supportsConfigFile": true,
    "supportsCoAuthor": true
  },
  "statusPage": {
    "adapter": "atlassian",
    "url": "https://status.claude.com/api/v2/summary.json",
    "componentId": "yyzkbfz2thpt",
    "componentName": "Claude Code"
  }
}
