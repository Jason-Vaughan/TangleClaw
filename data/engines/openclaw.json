{
  "id": "openclaw",
  "name": "OpenClaw",
  "pickerHidden": true,
  "command": "ssh",
  "interactionModel": "session",
  "configFormat": { "filename": null, "syntax": null, "generator": null },
  "coAuthorFormat": null,
  "commands": [],
  "detection": null,
  "launch": {
    "shellCommand": "ssh",
    "args": [],
    "env": {},
    "startupDelay": 3000
  },
  "persistent": null,
  "capabilities": {
    "supportsSlashCommands": false,
    "supportsPrimePrompt": false,
    "supportsConfigFile": false,
    "supportsCoAuthor": false,
    "supportsRemote": true,
    "supportsModes": ["ssh", "webui"]
  },
  "launchModes": {
    "default":           { "label": "Interactive",  "args": [], "bridgePermissionMode": "default",           "disabled": false, "description": "Prompts for permission on every action — surfaces ClawBridge's structured permission-review channel" },
    "acceptEdits":       { "label": "Accept Edits", "args": [], "bridgePermissionMode": "acceptEdits",       "disabled": false, "description": "Auto-accepts file reads and edits" },
    "plan":              { "label": "Plan Only",    "args": [], "bridgePermissionMode": "plan",              "disabled": false, "description": "Read-only, no code changes" },
    "auto":              { "label": "Auto",         "args": [], "bridgePermissionMode": "auto",              "disabled": false, "description": "Claude Code's auto-mode classifier decides" },
    "bypassPermissions": { "label": "Bypass",       "args": [], "bridgePermissionMode": "bypassPermissions", "disabled": false, "description": "Accepts everything (containers/VMs only)", "warning": "Only use in isolated environments" },
    "dontAsk":           { "label": "Don't Ask",    "args": [], "bridgePermissionMode": "dontAsk",           "disabled": false, "description": "Skip prompts but stop on dangerous actions" }
  },
  "defaultLaunchMode": "default",
  "statusPage": null,
  "remote": true
}
