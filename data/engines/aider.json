{
  "id": "aider",
  "name": "Aider",
  "command": "aider",
  "interactionModel": "session",
  "configFormat": {
    "filename": ".aider.conf.yml",
    "syntax": "yaml",
    "generator": "aider-conf"
  },
  "coAuthorFormat": "Co-Authored-By: {name} <{email}>",
  "commands": [
    { "label": "Add File", "input": "/add", "description": "Add file to context" },
    { "label": "Drop File", "input": "/drop", "description": "Remove file from context" },
    { "label": "Undo", "input": "/undo", "description": "Undo last change" }
  ],
  "detection": {
    "strategy": "which",
    "target": "aider"
  },
  "launch": {
    "shellCommand": "aider",
    "args": [],
    "env": {}
  },
  "launchModes": {
    "default": { "label": "Interactive", "args": [], "description": "Confirms before each change" },
    "yesAlways": { "label": "YOLO", "args": ["--yes-always"], "description": "Auto-confirms all prompts (aider --yes-always)", "warning": "Only use in isolated environments (containers/VMs)" }
  },
  "defaultLaunchMode": "default",
  "persistent": null,
  "capabilities": {
    "supportsSlashCommands": true,
    "supportsPrimePrompt": true,
    "supportsConfigFile": true,
    "supportsCoAuthor": true
  },
  "statusPage": null
}
