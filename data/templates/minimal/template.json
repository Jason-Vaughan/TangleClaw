{
  "id": "minimal",
  "name": "Minimal",
  "description": "Core rules only — changelog, JSDoc, tests, wrap protocol, PortHub. No methodology-specific workflow.",
  "type": "methodology",
  "version": "1.0.0",
  "phases": [],
  "statusContract": {
    "command": null,
    "parse": null,
    "field": null,
    "badge": "status",
    "colorMap": {}
  },
  "detection": {
    "strategy": "file",
    "target": ".tangleclaw/project.json"
  },
  "wrap_pipeline": {
    "schemaVersion": "1.0",
    "promptTemplates": {
      "claude": "Perform a session wrap. Commit all uncommitted work, then output a wrap summary."
    },
    "steps": [
      { "id": "learnings-capture", "kind": "ai-content", "prompt": "" },
      { "id": "memory-update",     "kind": "ai-content", "prompt": "", "captureFields": ["summary"] },
      { "id": "commit",            "kind": "commit" }
    ]
  },
  "prime": {
    "format": "markdown",
    "sections": ["active-learnings", "last-session-summary"],
    "maxTokens": 2000
  },
  "defaultRules": {},
  "actions": [],
  "hooks": {},
  "init": {
    "directories": [".tangleclaw"],
    "files": {},
    "postInit": null
  }
}
